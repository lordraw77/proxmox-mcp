# ── Proxmox VE ───────────────────────────────────────────────────────────────

# Token auth (recommended)
PROXMOX_MCP_HOST=192.168.1.10
PROXMOX_MCP_PORT=8006
PROXMOX_MCP_USER=root@pam
PROXMOX_MCP_TOKEN_ID=mytoken
PROXMOX_MCP_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_MCP_VERIFY_SSL=false

# Password auth (alternative — remove token vars above if using this)
# PROXMOX_MCP_PASSWORD=your_password

# ── MCP server Docker settings ────────────────────────────────────────────────
# Set PROXMOX_MCP_USE_DOCKER=true to spawn the MCP server inside a container
# instead of the local venv. The agent processes run on the host; only
# server.py is containerised.
PROXMOX_MCP_USE_DOCKER=false
PROXMOX_MCP_DOCKER_IMAGE=lordraw/proxmox-mcp:latest
# PROXMOX_MCP_ENV_FILE=.env   # path to .env forwarded to the container (default: .env)

# ── Provider selection ────────────────────────────────────────────────────────
# Active provider for all agents: openrouter | groq | gemini | cloudflare | cerebras | mistral
PROXMOX_MCP_PROVIDER=openrouter

# Maximum ReAct iterations for agent_sre.py (default: 20)
# PROXMOX_MCP_SRE_MAX_ITERATIONS=20

# ── OpenRouter ────────────────────────────────────────────────────────────────
PROXMOX_MCP_OPENROUTER_API_KEY=sk-or-...
PROXMOX_MCP_OPENROUTER_MODEL=anthropic/claude-haiku-4-5

# ── Groq ──────────────────────────────────────────────────────────────────────
PROXMOX_MCP_GROQ_API_KEY=gsk_...
PROXMOX_MCP_GROQ_MODEL=llama-3.3-70b-versatile

# ── Google Gemini ─────────────────────────────────────────────────────────────
PROXMOX_MCP_GEMINI_API_KEY=AIza...
PROXMOX_MCP_GEMINI_MODEL=gemini-2.0-flash

# ── Cloudflare Workers AI ─────────────────────────────────────────────────────
PROXMOX_MCP_CLOUDFLARE_API_KEY=...
PROXMOX_MCP_CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PROXMOX_MCP_CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# ── Cerebras ──────────────────────────────────────────────────────────────────
PROXMOX_MCP_CEREBRAS_API_KEY=csk-...
PROXMOX_MCP_CEREBRAS_MODEL=llama-3.3-70b

# ── Mistral ───────────────────────────────────────────────────────────────────
PROXMOX_MCP_MISTRAL_API_KEY=...
PROXMOX_MCP_MISTRAL_MODEL=mistral-large-latest

# ── Ollama (agent_ollama.py) ──────────────────────────────────────────────────
PROXMOX_MCP_OLLAMA_HOST=http://localhost:11434
PROXMOX_MCP_OLLAMA_MODEL=qwen2.5:7b-instruct
# PROXMOX_MCP_OLLAMA_TIMEOUT=120          # seconds to wait for each LLM response
# PROXMOX_MCP_OLLAMA_TOOL_TIMEOUT=30      # seconds to wait for each MCP tool call
# PROXMOX_MCP_OLLAMA_MAX_ITERATIONS=10    # max tool-call rounds per question
