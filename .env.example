# ── Proxmox VE ───────────────────────────────────────────────────────────────

# Token auth (recommended)
PROXMOX_HOST=192.168.1.10
PROXMOX_PORT=8006
PROXMOX_USER=root@pam
PROXMOX_TOKEN_ID=mytoken
PROXMOX_TOKEN_SECRET=xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
PROXMOX_VERIFY_SSL=false

# Password auth (alternative — remove token vars above if using this)
# PROXMOX_PASSWORD=your_password

# ── agent.py — OpenRouter ─────────────────────────────────────────────────────
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-opus-4-5

# ── agent_ollama.py — Ollama ──────────────────────────────────────────────────
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── agent_sre.py — SRE ReAct agent (multi-provider) ──────────────────────────

# Active provider: openrouter | groq | gemini | cloudflare | cerebras | mistral
SRE_PROVIDER=openrouter

# Maximum ReAct iterations before the agent stops (default: 20)
# SRE_MAX_ITERATIONS=20

# OpenRouter
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=openrouter/auto

# Groq
GROQ_API_KEY=gsk_...
GROQ_MODEL=llama-3.3-70b-versatile

# Google Gemini
GEMINI_API_KEY=AIza...
GEMINI_MODEL=gemini-2.0-flash

# Cloudflare Workers AI (also requires CLOUDFLARE_ACCOUNT_ID)
CLOUDFLARE_API_KEY=...
CLOUDFLARE_ACCOUNT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
CLOUDFLARE_MODEL=@cf/meta/llama-3.3-70b-instruct-fp8-fast

# Cerebras
CEREBRAS_API_KEY=csk-...
CEREBRAS_MODEL=llama-3.3-70b

# Mistral
MISTRAL_API_KEY=...
MISTRAL_MODEL=mistral-large-latest
